# ---------- Database (Supabase Postgres) ----------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://postgres:password@db.project.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct (non-pooled) connection for Prisma migrations.
DIRECT_URL="postgresql://postgres:password@db.project.supabase.co:5432/postgres"

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL="https://project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="public-anon-key"
# Server-only. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=""

# ---------- Telegram (blueprint §24) ----------
# Server-only secrets. Never prefix with NEXT_PUBLIC_.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_OWNER_CHAT_ID=""
# Only required if the inbound webhook is enabled.
TELEGRAM_WEBHOOK_SECRET=""

# ---------- Cron / background jobs ----------
# Shared secret for the notification retry endpoint.
CRON_SECRET=""
